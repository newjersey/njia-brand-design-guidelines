{
  "name": "njia-brand-design-guidelines",
  "version": "0.2.0",
  "private": true,
  "description": "Starlight documentation site for New Jersey Innovation Authority brand design guidelines.",
  "type": "module",
  "repository": "github:newjersey/njia-brand-design-guidelines",
  "homepage": "https://github.com/newjersey/njia-brand-design-guidelines",
  "bugs": "https://github.com/newjersey/njia-brand-design-guidelines/issues",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "astro check && astro build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check . && astro check",
    "check:fix": "biome check --write .",
    "prepare": "husky"
  },
  "keywords": [
    "brand-guidelines",
    "design-system",
    "documentation",
    "starlight"
  ],
  "author": {
    "name": "New Jersey Innovation Authority",
    "url": "https://github.com/newjersey"
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.1",
    "astro": "7.0.3"
  }
}
